#!/bin/sh
#|-*- mode:lisp -*-|#
#|
exec ros -Q -- $0 "$@"
|#

(defpackage :git-done
  (:use :cl))
(in-package :git-done)

(defvar *git-repo* nil
  "When non-nil, pass -C <dir> to every git invocation.")

(defun run (command)
  "Run a shell command and return its stdout as a string."
  (uiop:run-program command
                     :output '(:string :stripped t)
                     :error-output :interactive))

(defun git (&rest args)
  "Build a git command list, inserting -C *git-repo* when set."
  (if *git-repo*
      (list* "git" "-C" *git-repo* args)
      (cons "git" args)))

(defun git-config (key)
  (ignore-errors (run (git "config" key))))

(defun git-done-author ()
  (or (uiop:getenv "GIT_DONE_AUTHOR")
      (git-config "user.name")
      ""))

(defun parse-ref-line (line)
  "Parse a 'date<TAB>hash' line into (date . hash)."
  (let ((tab-pos (position #\Tab line)))
    (if tab-pos
        (cons (subseq line 0 tab-pos)
              (subseq line (1+ tab-pos)))
        (cons "" line))))

(defun parse-date-flag (prefix arg)
  "If ARG starts with PREFIX (e.g. \"--since=\"), return the value after it; else nil."
  (let ((len (length prefix)))
    (when (and (>= (length arg) len)
               (string= arg prefix :end1 len))
      (subseq arg len))))

(defun extract-date-args (extra-args)
  "Extract --since/--until values from EXTRA-ARGS.
Returns (values since-value until-value remaining-args)."
  (let (since until remaining (args extra-args))
    (loop while args do
      (let ((arg (pop args)))
        (cond
          ;; --since=VALUE
          ((parse-date-flag "--since=" arg)
           (setf since (parse-date-flag "--since=" arg)))
          ;; --since VALUE
          ((string= arg "--since")
           (setf since (pop args)))
          ;; --until=VALUE
          ((parse-date-flag "--until=" arg)
           (setf until (parse-date-flag "--until=" arg)))
          ;; --until VALUE
          ((string= arg "--until")
           (setf until (pop args)))
          (t (push arg remaining)))))
    (values since until (nreverse remaining))))

(defun date-to-unix (date-str flag)
  "Convert a date string to a unix timestamp using git rev-parse.
FLAG is \"--since\" or \"--until\"."
  (let* ((arg (format nil "~A=~A" flag date-str))
         (result (run (git "rev-parse" arg)))
         (eq-pos (position #\= result)))
    (parse-integer (subseq result (1+ eq-pos)))))

(defun git-done-lookback-days ()
  "Return the lookback window in days from GIT_DONE_LOOKBACK_DAYS, defaulting to 90."
  (let ((env (uiop:getenv "GIT_DONE_LOOKBACK_DAYS")))
    (if (and env (plusp (length env)))
        (parse-integer env)
        90)))

(defun batch-patch-ids (author since-arg)
  "Build a hash table mapping commit-hash → patch-id for all matching commits.
SINCE-ARG is a --since=... string to pass to git log, or nil for no limit."
  (let* ((git-prefix (if *git-repo*
                         (format nil "git -C ~A"
                                 (uiop:escape-shell-token *git-repo*))
                         "git"))
         (since-part (if since-arg
                         (format nil " ~A"
                                 (uiop:escape-shell-token since-arg))
                         ""))
         (shell-cmd (format nil "~A log --all --author=~A --no-merges~A -p | git patch-id --stable"
                            git-prefix
                            (uiop:escape-shell-token author)
                            since-part))
         (output (ignore-errors
                   (uiop:run-program shell-cmd
                                     :output '(:string :stripped t)
                                     :error-output :interactive)))
         (table (make-hash-table :test #'equal)))
    (when (and output (plusp (length output)))
      (dolist (line (uiop:split-string output :separator '(#\Newline)))
        (let ((space (position #\Space line)))
          (when space
            (let ((pid (subseq line 0 space))
                  (hash (subseq line (1+ space))))
              (setf (gethash hash table) pid))))))
    table))

(defun dedup-by-patch-id (entries patch-ids)
  "Remove duplicate commits by patch-id, keeping the one with the oldest
committer date (earliest appearance of the logical change).
PATCH-IDS is a hash table mapping commit-hash → patch-id."
  (let ((seen (make-hash-table :test #'equal))
        (result nil))
    ;; Sort by committer-date ascending so we see oldest first
    (dolist (entry (sort (copy-list entries) #'string< :key #'car))
      (let* ((hash (cdr entry))
             (pid (gethash hash patch-ids)))
        (cond
          ((null pid)
           ;; Empty commits have no patch-id; always keep them
           (push entry result))
          ((not (gethash pid seen))
           (setf (gethash pid seen) t)
           (push entry result)))))
    result))

(defun commit-refs (author extra-args)
  "Return a list of (committer-unix-ts . hash), sorted by committer date descending.
Buckets by committer date so that amended commits appear on the day they were amended.
Uses a lookback window (GIT_DONE_LOOKBACK_DAYS, default 90) to fetch older commits
for patch-id deduplication, then filters survivors to the user's --since/--until range."
  (multiple-value-bind (since-str until-str remaining-args)
      (extract-date-args extra-args)
    (let* ((since-ts (when since-str (date-to-unix since-str "--since")))
           (until-ts (when until-str (date-to-unix until-str "--until")))
           (lookback-days (git-done-lookback-days))
           (lookback-since-ts (when since-ts
                                 (- since-ts (* lookback-days 86400))))
           ;; Pass lookback --since to git (broader window for dedup)
           (git-date-args (when lookback-since-ts
                            (list (format nil "--since=@~A" lookback-since-ts))))
           (since-arg (when lookback-since-ts
                        (format nil "--since=@~A" lookback-since-ts)))
           (fmt (format nil "--pretty=%ct~C%H" #\Tab))
           (output (run `(,@(git "log")
                          "--all"
                          ,(format nil "--author=~A" author)
                          ,fmt
                          "--no-merges"
                          ,@git-date-args
                          ,@remaining-args)))
           (patch-ids (batch-patch-ids author since-arg)))
      (when (and output (plusp (length output)))
        (let* ((entries (mapcar #'parse-ref-line
                                (uiop:split-string output
                                                   :separator '(#\Newline))))
               ;; Dedup BEFORE filtering to user's range
               (deduped (dedup-by-patch-id entries patch-ids))
               ;; Filter survivors to user's --since/--until range
               (filtered (remove-if-not
                          (lambda (entry)
                            (let ((ts (parse-integer (car entry))))
                              (and (or (null since-ts) (>= ts since-ts))
                                   (or (null until-ts) (< ts until-ts)))))
                          deduped)))
          (sort filtered #'string> :key #'car))))))

(defun commit-subject (hash)
  (run (git "log" "-1" "--pretty=%s" hash)))

(defun commit-date (hash)
  (run (git "log" "-1" "--pretty=%ad" "--date=iso" hash)))

(defun commit-body (hash)
  (run (git "log" "-1" "--pretty=%b" hash)))

(defun commit-patch (hash)
  (run (git "diff-tree" "-p" "--no-commit-id" "--root" hash)))

(defun max-consecutive-run (char text)
  "Find the longest consecutive run of CHAR anywhere in TEXT."
  (let ((max-run 0)
        (cur-run 0))
    (loop for c across text do
      (if (char= c char)
          (incf cur-run)
          (setf cur-run 0))
      (when (> cur-run max-run)
        (setf max-run cur-run)))
    max-run))

(defun fence-for (text)
  "Return a backtick fence long enough to wrap TEXT safely."
  (make-string (max 3 (1+ (max-consecutive-run #\` text))) :initial-element #\`))

(defun escape-body-headings (body)
  "Ensure any heading lines in BODY nest under the ### commit heading.
Lines starting with # get extra # prepended so they have at least 4."
  (let ((lines (uiop:split-string body :separator '(#\Newline))))
    (format nil "~{~A~^~%~}"
            (mapcar (lambda (line)
                      (let ((run (or (position-if (lambda (c) (char/= c #\#)) line)
                                     (length line))))
                        (if (plusp run)
                            (concatenate 'string
                                         (make-string (max 0 (- 4 run)) :initial-element #\#)
                                         line)
                            line)))
                    lines))))

(defun format-commit (hash)
  "Format a single commit as markdown."
  (let ((subject (commit-subject hash))
        (date (commit-date hash))
        (body (commit-body hash))
        (patch (commit-patch hash)))
    (let ((fence (fence-for patch)))
      (with-output-to-string (s)
        (format s "### ~A~%~%**~A** `~A`~%" subject date hash)
        (when (and body (plusp (length body)))
          (format s "~%~A~%" (escape-body-headings body)))
        (format s "~%~Adiff~%~A~%~A" fence patch fence)))))

(defun parse-argv (argv)
  "Extract -C <dir> from ARGV, returning (values repo-dir remaining-args)."
  (let (repo remaining)
    (loop while argv do
      (let ((arg (pop argv)))
        (cond ((string= arg "-C")
               (setf repo (pop argv)))
              (t (push arg remaining)))))
    (values repo (nreverse remaining))))

(defun main (&rest argv)
  (multiple-value-bind (repo extra-args) (parse-argv argv)
    (let ((*git-repo* repo))
      (let* ((author (git-done-author))
             (refs (commit-refs author extra-args)))
        (dolist (ref refs)
          (let ((hash (cdr ref)))
            (write-string (format-commit hash))
            (terpri)
            (terpri)))))))
